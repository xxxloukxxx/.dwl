+} Rule_match_type_next;
+typedef enum {
+    ZRIVER_RULE_TYPE_NONE=0,
+    ZRIVER_RULE_TYPE_TAGS,
+    ZRIVER_RULE_TYPE_MONITOR,
+} Rule_type;
