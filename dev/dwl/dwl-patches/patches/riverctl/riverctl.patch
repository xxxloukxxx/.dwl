+    STR(toggletag,FUNC_STR_ARG_TYPE_UINT),
+    STR(togglefullscreen,FUNC_STR_ARG_TYPE_NONE),
+    STR(quit,FUNC_STR_ARG_TYPE_NONE),
+};
