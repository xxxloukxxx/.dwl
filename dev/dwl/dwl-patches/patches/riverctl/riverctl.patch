+    {0,"none"},
+    {WLR_MODIFIER_LOGO,"super"},
+    {WLR_MODIFIER_LOGO,"logo"},
+    {WLR_MODIFIER_CTRL,"ctrl"},
+    {WLR_MODIFIER_ALT,"alt"},
+    {WLR_MODIFIER_SHIFT,"shift"},
+    {WLR_MODIFIER_CAPS,"caps"},
